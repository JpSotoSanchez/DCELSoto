        ax.plot([seg.p1.x, seg.p2.x], [seg.p1.y, seg.p2.y],
                color='#cccccc', lw=1, zorder=1)

    # Segmentos activos en T resaltados en azul
    for seg in frame['activos']:
        ax.plot([seg.p1.x, seg.p2.x], [seg.p1.y, seg.p2.y],
                color='steelblue', lw=2, zorder=2)

    # Línea de barrido
    ax.axhline(y=frame['y'], color='limegreen', linestyle='--', lw=1.2,
               zorder=3, label=f"y = {frame['y']:.2f}")

    # Intersecciones encontradas hasta este momento
    for punto, segs in frame['resultado']:
        ax.plot(punto.x, punto.y, 'ro', markersize=5, zorder=4)

    # Punto del evento actual
    ax.plot(frame['punto'].x, frame['punto'].y, '*',
            color='gold', markersize=12, zorder=5, markeredgewidth=0.8)

    ax.set_title(
        f"Evento {i + 1} / {len(frames)}  |  "
        f"tipo: {frame['tipo']}  |  "
        f"intersecciones: {len(frame['resultado'])}",
        fontsize=10
    )

ani = animation.FuncAnimation(
    fig, update,
    frames=len(frames),
    interval=80,       # ms por frame; bajar para acelerar
    repeat=False,
)

plt.tight_layout()


# ── Guardar como MP4 ──────────────────────────────────────────────────────────

filename = "barrido3.mp4"
fps      = 2          # fotogramas por segundo en el video

ani.save(filename, writer="ffmpeg", fps=fps)
plt.close()
print(f"Animación guardada como {filename}")
