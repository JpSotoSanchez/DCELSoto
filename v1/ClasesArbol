@dataclass(frozen=True)
class Punto:
    x: float
    y: float

    def distancia(self, otro: "Punto") -> float:
        return math.hypot(self.x - otro.x, self.y - otro.y)


@dataclass(frozen=True)
class Segmento:
    name: str
    p1: Punto
    p2: Punto
    boundingBox: tuple = field(init=False)
    long: float = field(init=False)
    ang: float = field(init=False)
    
    def __repr__(self):
        return f"Segmento {self.name} p1={self.p1}, p2={self.p2}"

    def __post_init__(self):
        object.__setattr__(self, "boundingBox", (
            min(self.p1.x, self.p2.x),
            max(self.p1.x, self.p2.x),
            min(self.p1.y, self.p2.y),
            max(self.p1.y, self.p2.y)
        ))
        longitud = self.p1.distancia(self.p2)
        object.__setattr__(self, "long", longitud)

        if longitud == 0:
            object.__setattr__(self, "ang", 0.0)
        else:
            valor = abs((self.p1.x - self.p2.x) / longitud)
            valor = max(-1.0, min(1.0, valor))
            object.__setattr__(self, "ang", math.acos(valor))

    def organAlto(self) -> "Segmento":
        """Devuelve un nuevo segmento con p1 como el punto más alto."""
        if self.p1.y > self.p2.y:
            return self
        elif self.p1.y == self.p2.y:
            if self.p1.x < self.p2.x:
                return self
            else:
                return Segmento(self.name, self.p2, self.p1)
        else:
            return Segmento(self.name, self.p2, self.p1)

    def yInBound(self, altura: float) -> bool:
        return self.boundingBox[2] <= altura <= self.boundingBox[3]

    def __hash__(self):
        return hash((self.p1, self.p2))

    
class Nodo:
    def __init__(self, valor):
        self.valor = valor
        self.padre = None
        self.izq = None
        self.der = None
        self.x = None
        self.y = None

    def hijos(self):
        r = []
        if self.izq:
            r.append(self.izq)
        if self.der:
            r.append(self.der)
        return r

    def __repr__(self):
        return f"Nodo {self.valor}"


# ── Funciones auxiliares globales ────────────────────────────────────────────

def altura(nodo):
    """Altura del subárbol enraizado en `nodo`. Nodo None → -1."""
    if nodo is None:
        return -1
    prof_izq = altura(nodo.izq)
    prof_der = altura(nodo.der)
    return 1 + max(prof_izq, prof_der)

def mayor(nodo):
    while nodo.der:
        nodo = nodo.der
    return nodo


# ── Función auxiliar: x de un segmento a una altura dada ─────────────────────

def x_at_y(seg: "Segmento", y: float) -> float:
    """Devuelve la coordenada x del segmento en la altura y."""
    if abs(seg.p1.y - seg.p2.y) < 1e-10:   # segmento horizontal
        return seg.p1.x
    t = (y - seg.p1.y) / (seg.p2.y - seg.p1.y)
    return seg.p1.x + t * (seg.p2.x - seg.p1.x)


# ── Árbol AVL ────────────────────────────────────────────────────────────────

class AVL:
    def __init__(self):
        self.raiz = None

    # ── utilidades de balance ────────────────────────────────────────────────

    def _altura(self, nodo):
        return altura(nodo)

    def _factor(self, nodo):
        if nodo is None:
            return 0
        return self._altura(nodo.izq) - self._altura(nodo.der)

    # ── rotaciones ──────────────────────────────────────────────────────────

    def _rotar_derecha(self, y):
        x = y.izq
        t2 = x.der

        x.padre = y.padre
        if y.padre is None:
            self.raiz = x
        elif y.padre.izq == y:
            y.padre.izq = x
        else:
            y.padre.der = x

        x.der = y
        y.padre = x

        y.izq = t2
        if t2:
            t2.padre = y

        return x

    def _rotar_izquierda(self, x):
        y = x.der
        t2 = y.izq

        y.padre = x.padre
        if x.padre is None:
            self.raiz = y
        elif x.padre.izq == x:
            x.padre.izq = y
        else:
            x.padre.der = y

        y.izq = x
        x.padre = y

        x.der = t2
        if t2:
            t2.padre = x

        return y

    def _rebalancear(self, nodo):
        actual = nodo
        while actual is not None:
            fb = self._factor(actual)

            if fb > 1:
                if self._factor(actual.izq) < 0:
                    self._rotar_izquierda(actual.izq)
                self._rotar_derecha(actual)

            elif fb < -1:
                if self._factor(actual.der) > 0:
                    self._rotar_derecha(actual.der)
                self._rotar_izquierda(actual)

            actual = actual.padre

    # ── insertar ────────────────────────────────────────────────────────────

    @staticmethod
    def _clave(seg):
        """Clave de comparación: x en y_sweep, con ángulo como desempate."""
        return (x_at_y(seg, y_sweep), seg.ang)

    def insertar(self, valor):
        if not self.raiz:
            self.raiz = Nodo(valor)
            return self.raiz

        vk = self._clave(valor)
        actual = self.raiz
        while True:
            ak = self._clave(actual.valor)
            if actual.valor is valor:
                return actual
            elif vk < ak:
                if not actual.izq:
                    nuevo = Nodo(valor)
                    nuevo.padre = actual
                    actual.izq = nuevo
                    self._rebalancear(actual)
                    return nuevo
                actual = actual.izq
            else:
                if not actual.der:
                    nuevo = Nodo(valor)
                    nuevo.padre = actual
                    actual.der = nuevo
                    self._rebalancear(actual)
                    return nuevo
                actual = actual.der

    # ── buscar ──────────────────────────────────────────────────────────────

    def buscar(self, valor):
        return self.buscarPorIdentidad(valor)

    def buscarContenedores(self, p: "Punto") -> set:
        """Devuelve el conjunto de segmentos en T que contienen p en su interior."""
        resultado = set()
        for nodo in self.inorden():
            seg = nodo.valor
            if seg.p1 == p or seg.p2 == p:
                continue
            if seg.yInBound(p.y):
                if abs(x_at_y(seg, p.y) - p.x) < 1e-9:
                    resultado.add(seg)
        return resultado

    def buscarVecinosDeX(self, px: float):
        """Devuelve (nodo_izq, nodo_der) más cercanos a px usando inorden."""
        nodos = self.inorden()
        izq = None
        der = None
        for n in nodos:
            ax = x_at_y(n.valor, y_sweep)
            if ax < px - 1e-9:
                izq = n
            elif ax > px + 1e-9:
                if der is None:
                    der = n
        return izq, der

    def buscarEnRangoX(self, x_min: float, x_max: float) -> list:
        """Devuelve todos los nodos cuya x en y_sweep cae dentro de [x_min, x_max]."""
        resultado = []
        for nodo in self.inorden():
            nx = x_at_y(nodo.valor, y_sweep)
            if x_min - 1e-9 <= nx <= x_max + 1e-9:
                resultado.append(nodo)
        return resultado

    def buscarPorIdentidad(self, seg) -> "Nodo":
        """Busca el nodo cuyo valor ES el mismo objeto que seg (por identidad)."""
        for nodo in self.inorden():
            if nodo.valor is seg:
                return nodo
        return None

    def sucesor(self, nodo):
        """Sucesor en el orden actual de y_sweep (inorden dinámico)."""
        if nodo is None:
            return None
        nodos = self.inorden()
        for i, n in enumerate(nodos):
            if n is nodo:
                return nodos[i+1] if i+1 < len(nodos) else None
        return None

    def predecesor(self, nodo):
        """Predecesor en el orden actual de y_sweep (inorden dinámico)."""
        if nodo is None:
            return None
        nodos = self.inorden()
        for i, n in enumerate(nodos):
            if n is nodo:
                return nodos[i-1] if i > 0 else None
        return None

    # ── eliminar ────────────────────────────────────────────────────────────

    def eliminar(self, valor):
        nodo = self.buscarPorIdentidad(valor)
        if nodo:
            self._eliminar_nodo(nodo)

    def _eliminar_nodo(self, nodo):
        inicio_rebalanceo = nodo.padre

        if not nodo.izq and not nodo.der:
            if nodo == self.raiz:
                self.raiz = None
            else:
                padre = nodo.padre
                if padre.izq == nodo:
                    padre.izq = None
                else:
                    padre.der = None

        elif nodo.izq and not nodo.der:
            self._reemplazar_con_hijo(nodo, nodo.izq)

        elif nodo.der and not nodo.izq:
            self._reemplazar_con_hijo(nodo, nodo.der)

        else:
            sucesor = mayor(nodo.izq)
            inicio_rebalanceo = sucesor.padre
            if inicio_rebalanceo == nodo:
                inicio_rebalanceo = sucesor
            nodo.valor = sucesor.valor
            self._eliminar_nodo(sucesor)
            return

        if inicio_rebalanceo:
            self._rebalancear(inicio_rebalanceo)

    def _reemplazar_con_hijo(self, nodo, hijo):
        hijo.padre = nodo.padre
        if nodo.padre is None:
            self.raiz = hijo
        elif nodo.padre.izq == nodo:
            nodo.padre.izq = hijo
        else:
            nodo.padre.der = hijo

    # ── recorridos ──────────────────────────────────────────────────────────

    def _inorden_estructural(self, nodo=None):
        """Recorrido inorden por estructura del árbol (sin reordenar)."""
        if nodo is None:
            nodo = self.raiz
        l = []
        if nodo is None:
            return l
        if nodo.izq:
            l.extend(self._inorden_estructural(nodo.izq))
        l.append(nodo)
        if nodo.der:
            l.extend(self._inorden_estructural(nodo.der))
        return l

    def inorden(self, nodo=None):
        """Devuelve nodos ordenados por x_at_y(seg, y_sweep) actual."""
        nodos = self._inorden_estructural(nodo)
        nodos.sort(key=lambda n: x_at_y(n.valor, y_sweep))
        return nodos


